{
  "name": "apd-astrophotography-dashboard",
  "version": "1.1.1",
  "description": "Astrophotography Planning Dashboard — unified weather forecasts, interactive sky chart, and AI-friendly forecast summaries for astrophotographers.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/giancarloerra/apd.git"
  },
  "homepage": "https://github.com/giancarloerra/apd#readme",
  "bugs": {
    "url": "https://github.com/giancarloerra/apd/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "client:dev": "vite",
    "server:dev": "nodemon --watch server --ignore server/data --exec node server/index.js",
    "build": "vite build",
    "build:server": "echo 'Server build complete'",
    "start": "node server/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "release": "release-it"
  },
  "dependencies": {
    "@upstash/redis": "^1.36.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.35",
    "release-it": "^19.2.4",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vitest": "^4.0.18"
  }
}
